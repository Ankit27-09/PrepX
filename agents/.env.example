# Shared Environment Configuration for All Agents
# Copy this to .env and fill in the values

# LiveKit Configuration (for real-time voice/video)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AWS Configuration (for S3 video storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

# Groq API (for LLM resume parsing)
GROQ_API_KEY=

# Google Gemini (for realtime AI model)
GOOGLE_API_KEY=

# Beyond Presence Avatar
BEY_API_KEY=
BEY_AVATAR_ID=

# Gmail for Session Summaries (used by AI Tutor)
GMAIL_USER=
GMAIL_APP_PASSWORD=
